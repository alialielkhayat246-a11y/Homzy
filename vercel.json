{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["backend/**", "frontend/**", "data/**"]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "api/index.py" }
  ],
  "env": {
    "LLM_PROVIDER": "gemini",
    "GEMINI_MODEL": "gemini-flash-latest",
    "BROKER_NAME": "Homzy",
    "BRAND_NAME": "Homzy"
  }
}
