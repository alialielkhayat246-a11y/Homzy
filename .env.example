# Copy this file to ".env" and adjust as you like.

# ---- LLM engine (all free) -------------------------------------------------
# ollama -> local, free, no key, runs on this PC          (recommended)
# gemini -> Google AI Studio free tier (needs a free key)
# mock   -> no AI engine; templated replies only (instant preview, no install)
LLM_PROVIDER=ollama

# -- Ollama (local) --
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b

# -- Gemini (free cloud tier) — uncomment to use --
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=get_a_free_key_at_https://aistudio.google.com/apikey
# GEMINI_MODEL=gemini-flash-latest

# ---- Brand / persona -------------------------------------------------------
BRAND_NAME=Homzy
BROKER_NAME=Nour

# ---- Admin panel (Phase 2) -------------------------------------------------
# Password for the listings admin panel at /admin. Leave blank for local,
# single-user use; set it before exposing Homzy on a network.
ADMIN_TOKEN=

# ---- Behaviour -------------------------------------------------------------
MAX_RESULTS=4
LLM_TEMPERATURE=0.6
